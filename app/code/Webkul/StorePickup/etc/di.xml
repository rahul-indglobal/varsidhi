<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
		<preference for="Webkul\StorePickup\Api\StoresRepositoryInterface" type="Webkul\StorePickup\Model\StoresRepository"/>
		<preference for="Webkul\StorePickup\Api\Data\StoresInterface" type="Webkul\StorePickup\Model\Stores"/>
		<preference for="Webkul\StorePickup\Api\Data\StoresSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>

		<preference for="Webkul\StorePickup\Api\StoresProductsRelationRepositoryInterface" type="Webkul\StorePickup\Model\StoresProductsRelationRepository"/>
		<preference for="Webkul\StorePickup\Api\Data\StoresProductsRelationInterface" type="Webkul\StorePickup\Model\StoresProductsRelation"/>
		<preference for="Webkul\StorePickup\Api\Data\StoresProductsRelationSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>

		<virtualType name="Webkul\StorePickup\Model\ResourceModel\Stores\Grid\Collection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
				<arguments>
						<argument name="mainTable" xsi:type="string">webkul_storepickup_stores</argument>
						<argument name="resourceModel" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Collection</argument>
				</arguments>
		</virtualType>

		<type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
				<arguments>
						<argument name="collections" xsi:type="array">
								<item name="storepickup_stores_listing_data_source" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Grid\Collection</item>
						</argument>
				</arguments>
		</type>

		<type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
				<arguments>
						<argument name="collections" xsi:type="array">
								<item name="storepickup_stores_assign_listing_data_source" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Grid\Collection</item>
						</argument>
				</arguments>
		</type>

		<!-- Register the Abstract Repositories -->
    <type name="Magento\Framework\Model\Entity\RepositoryFactory">
        <arguments>
            <argument name="entities" xsi:type="array">
                <item name="Webkul\StorePickup\Api\Data\StoresInterface" xsi:type="string">Webkul\StorePickup\Api\StoresRepositoryInterface</item>
            </argument>
        </arguments>
    </type>

		<!-- Register the entities to the Entity Persistence Manager -->
    <type name="Magento\Framework\EntityManager\MetadataPool">
        <arguments>
            <argument name="metadata" xsi:type="array">
                <item name="Webkul\StorePickup\Api\Data\StoresInterface" xsi:type="array">
                    <item name="entityTableName" xsi:type="string">webkul_storepickup_stores</item>
                    <item name="identifierField" xsi:type="string">entity_id</item>
                </item>
            </argument>
        </arguments>
    </type>

		<!-- Add extra operation to the entities persistence, like external relations -->
    <type name="Magento\Framework\EntityManager\Operation\ExtensionPool">
        <arguments>
            <argument name="extensionActions" xsi:type="array">
                <item name="Webkul\StorePickup\Api\Data\StoresInterface" xsi:type="array">
                    <item name="read" xsi:type="array">
                        <item name="storesReader" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Relation\ReadHandler</item>
                    </item>
                    <item name="create" xsi:type="array">
                        <item name="storesCreator" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Relation\SaveHandler</item>
                    </item>
                    <item name="update" xsi:type="array">
                        <item name="storesUpdater" xsi:type="string">Webkul\StorePickup\Model\ResourceModel\Stores\Relation\SaveHandler</item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>

		<!-- Register the hydrator strategy for our entities -->
    <type name="Magento\Framework\EntityManager\HydratorPool">
        <arguments>
            <argument name="hydrators" xsi:type="array">
                <item name="Webkul\StorePickup\Api\Data\StoresInterface" xsi:type="string">Magento\Framework\EntityManager\AbstractModelHydrator</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Checkout\Model\ShippingInformationManagement">
        <plugin name="save_to_quote_table" type="Webkul\StorePickup\Plugin\Quote\SaveToQuote" sortOrder="10" />
    </type>
</config>
