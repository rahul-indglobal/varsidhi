<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
		<argument name="data" xsi:type="array">
				<item name="js_config" xsi:type="array">
						<item name="provider" xsi:type="string">storepickup_stores_listing.storepickup_stores_listing_data_source</item>
				</item>
		</argument>

		<settings>
				<spinner>webkul_storepickup_stores_columns</spinner>
				<deps>
						<dep>storepickup_stores_listing.storepickup_stores_listing_data_source</dep>
				</deps>
				<buttons>
						<button name="add">
								<url path="*/*/new"/>
								<class>primary</class>
								<label translate="true">Add Store</label>
						</button>
				</buttons>
		</settings>

		<dataSource component="Magento_Ui/js/grid/provider" name="storepickup_stores_listing_data_source">
				<settings>
						<updateUrl path="mui/index/render"/>
				</settings>
				<aclResource>Webkul_StorePickup::pickupstores</aclResource>
				<dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="storepickup_stores_listing_data_source">
						<settings>
								<requestFieldName>id</requestFieldName>
								<primaryFieldName>entity_id</primaryFieldName>
						</settings>
				</dataProvider>
		</dataSource>

		<listingToolbar name="listing_top">
				<bookmark name="bookmarks"/>
				<columnsControls name="columns_controls"/>
				<filters name="listing_filters"/>
				<paging name="listing_paging"/>
		</listingToolbar>

		<massaction name="listing_massaction">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="selectProvider" xsi:type="string">storepickup_stores_listing.storepickup_stores_listing.webkul_storepickup_stores_columns.ids</item>
                <item name="indexField" xsi:type="string">entity_id</item>
            </item>
        </argument>

        <action name="enable">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="type" xsi:type="string">enable</item>
                    <item name="label" xsi:type="string" translate="true">Enable</item>
                    <item name="url" xsi:type="url" path="storepickup/stores/massenable"/>
                    <item name="confirm" xsi:type="array">
                        <item name="title" xsi:type="string" translate="true">Enable</item>
                        <item name="message" xsi:type="string" translate="true">Are you sure want to enable Store(s) ?</item>
                    </item>
                </item>
            </argument>
        </action>

        <action name="disable">
						<argument name="data" xsi:type="array">
								<item name="config" xsi:type="array">
										<item name="type" xsi:type="string">disable</item>
										<item name="label" xsi:type="string" translate="true">Disable</item>
										<item name="url" xsi:type="url" path="storepickup/stores/massdisable"/>
										<item name="confirm" xsi:type="array">
												<item name="title" xsi:type="string" translate="true">Disable</item>
												<item name="message" xsi:type="string" translate="true">Are you sure want to disable Store(s) ?</item>
										</item>
								</item>
						</argument>
        </action>

        <action name="delete">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="type" xsi:type="string">delete</item>
                    <item name="label" xsi:type="string" translate="true">Delete</item>
                    <item name="url" xsi:type="url" path="storepickup/stores/massdelete"/>
                    <item name="confirm" xsi:type="array">
                        <item name="title" xsi:type="string" translate="true">Delete</item>
                        <item name="message" xsi:type="string" translate="true">Are you sure want to delete Store(s) ?</item>
                    </item>
                </item>
            </argument>
        </action>
    </massaction>

		<columns name="webkul_storepickup_stores_columns">
				<selectionsColumn name="ids">
						<settings>
								<indexField>entity_id</indexField>
						</settings>
				</selectionsColumn>

				<column name="entity_id">
						<settings>
								<filter>textRange</filter>
								<sorting>desc</sorting>
								<label translate="true">ID</label>
						</settings>
				</column>

				<column name="name">
						<settings>
								<filter>text</filter>
								<label translate="true">Name</label>
						</settings>
				</column>

				<column name="is_enabled" class="Webkul\StorePickup\Ui\Component\Listing\Columns\YesNo">
						<settings>
								<options class="Webkul\StorePickup\Ui\Component\Listing\Options\YesNo"/>
								<filter>select</filter>
								<dataType>select</dataType>
								<label translate="true">Enabled</label>
						</settings>
				</column>

				<column name="latitude">
						<settings>
								<filter>text</filter>
								<label translate="true">Latitude</label>
						</settings>
				</column>

				<column name="longitude">
						<settings>
								<filter>text</filter>
								<label translate="true">Longitude</label>
						</settings>
				</column>

				<column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
      			<settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
    				    <label translate="true">Created At</label>
      			</settings>
    		</column>

				<actionsColumn class="Webkul\StorePickup\Ui\Component\Listing\Columns\StoresDetailsActions" name="actions">
						<settings>
								<indexField>entity_id</indexField>
								<resizeEnabled>false</resizeEnabled>
								<resizeDefaultWidth>107</resizeDefaultWidth>
						</settings>
				</actionsColumn>
		</columns>
</listing>
