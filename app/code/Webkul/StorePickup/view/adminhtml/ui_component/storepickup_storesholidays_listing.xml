<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
		<argument name="data" xsi:type="array">
				<item name="js_config" xsi:type="array">
						<item name="provider" xsi:type="string">storepickup_storesholidays_listing.storepickup_storesholidays_listing_data_source</item>
				</item>
		</argument>

		<settings>
				<spinner>storepickup_storesholidays_columns</spinner>
				<deps>
						<dep>storepickup_storesholidays_listing.storepickup_storesholidays_listing_data_source</dep>
				</deps>
				<buttons>
						<button name="add">
								<url path="*/*/new"/>
								<class>primary</class>
								<label translate="true">Add New Holiday</label>
						</button>
				</buttons>
		</settings>

		<dataSource component="Magento_Ui/js/grid/provider" name="storepickup_storesholidays_listing_data_source">
				<settings>
						<updateUrl path="mui/index/render"/>
				</settings>
				<aclResource>Webkul_StorePickup::pickupholidays</aclResource>
        <dataProvider class="Webkul\StorePickup\Ui\DataProvider\StoresHolidays\StoresHolidaysDataProvider" name="storepickup_storesholidays_listing_data_source">
						<settings>
								<requestFieldName>id</requestFieldName>
								<primaryFieldName>entity_id</primaryFieldName>
						</settings>
				</dataProvider>
		</dataSource>

		<listingToolbar name="listing_top">
				<settings>
						<sticky>true</sticky>
				</settings>
				<bookmark name="bookmarks"/>
				<columnsControls name="columns_controls"/>
				<filters name="listing_filters"/>
				<paging name="listing_paging"/>
		</listingToolbar>

		<columns name="storepickup_storesholidays_columns">
				<settings>
						<editorConfig>
								<param name="selectProvider" xsi:type="string">storepickup_storesholidays_listing.storepickup_storesholidays_listing.storepickup_storesholidays_columns.ids</param>
								<param name="enabled" xsi:type="boolean">true</param>
								<param name="indexField" xsi:type="string">entity_id</param>
								<param name="clientConfig" xsi:type="array">
										<item name="saveUrl" path="storepickup/StoresHolidays/inlineEdit" xsi:type="url"/>
										<item name="validateBeforeSave" xsi:type="boolean">false</item>
								</param>
						</editorConfig>
						<childDefaults>
								<param name="fieldAction" xsi:type="array">
										<item name="provider" xsi:type="string">storepickup_storesholidays_listing.storepickup_storesholidays_listing.storepickup_storesholidays_columns_editor</item>
										<item name="target" xsi:type="string">startEdit</item>
										<item name="params" xsi:type="array">
												<item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
												<item name="1" xsi:type="boolean">true</item>
										</item>
								</param>
						</childDefaults>
				</settings>

				<selectionsColumn name="ids">
						<settings>
								<indexField>entity_id</indexField>
						</settings>
				</selectionsColumn>

				<column name="entity_id" sortOrder="10">
						<settings>
								<filter>textRange</filter>
								<label translate="true">ID</label>
						</settings>
				</column>

				<column name="name" sortOrder="20">
						<settings>
								<filter>text</filter>
								<label translate="true">Holiday Name</label>
						</settings>
				</column>

				<column name="from_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
						<settings>
								<filter>dateRange</filter>
								<dataType>date</dataType>
								<label translate="true">From Date</label>
						</settings>
				</column>

				<column name="to_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
						<settings>
								<filter>dateRange</filter>
								<dataType>date</dataType>
								<label translate="true">To Date</label>
						</settings>
				</column>

				<column name="status" class="Webkul\StorePickup\Ui\Component\Listing\Columns\EnabledDisabled" sortOrder="40">
						<settings>
								<options class="Webkul\StorePickup\Ui\Component\Listing\Options\EnabledDisabled"/>
								<filter>select</filter>
								<dataType>select</dataType>
								<label translate="true">Status</label>
						</settings>
				</column>

				<actionsColumn class="Webkul\StorePickup\Ui\Component\Listing\Columns\StoresHolidaysActions" name="actions" sortOrder="50">
						<settings>
								<indexField>entity_id</indexField>
								<resizeEnabled>false</resizeEnabled>
								<resizeDefaultWidth>107</resizeDefaultWidth>
						</settings>
				</actionsColumn>
		</columns>
</listing>
