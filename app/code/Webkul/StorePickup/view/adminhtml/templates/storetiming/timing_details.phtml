                                value="<%- item.startTime%>"
                                id="time-start-<%- index %>"
                                name="stores_timings[timings][time-start-<%- index %>]"
                                data-form-part="storepickup_stores_form" />
                        </div>
                    </td>

                    <td class="right-border-remove left-border-remove">
                        <div class="admin__field text-align-center">
                            <div class="dash-seperator">-</div>
                        </div>
                    </td>

                    <td class="left-border-remove">
                        <div class="admin__field text-align-center">
                            <input
                                type="text"
                                readOnly
                                class="admin__control-text timepicker-end"
                                value="<%- item.endTime%>"
                                id="time-end-<%- index %>"
                                name="stores_timings[timings][time-end-<%- index %>]"
                                data-form-part="storepickup_stores_form" />
