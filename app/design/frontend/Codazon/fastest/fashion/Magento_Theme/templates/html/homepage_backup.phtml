<script type="text/javascript">
    require(['jquery'], function(jQuery){

        jQuery(window).scroll(function() {
            var top_of_element = jQuery("#video-wrapper").offset().top;
            var bottom_of_element = jQuery("#video-wrapper").offset().top + jQuery("#video-wrapper").outerHeight();
            var bottom_of_screen = jQuery(window).scrollTop() + jQuery(window).innerHeight();
            var top_of_screen = jQuery(window).scrollTop();

            if ((bottom_of_screen > top_of_element) && (top_of_screen < bottom_of_element)){
                setTimeout(() => {
                    jQuery('#video-wrapper .iframe-wrapper').addClass('active');
                    jQuery('#video-wrapper iframe').css({'display': 'block'});
                    if(jQuery("#video-wrapper iframe").attr('src') == ""){
                        jQuery("#video-wrapper iframe#first-iframe").attr('src',"https://www.youtube.com/embed/o_rKoLY2OK4?autoplay=1&loop=1&mute=1&playlist=o_rKoLY2OK4");
                        jQuery("#video-wrapper iframe#second-iframe").attr('src',"https://www.youtube.com/embed/o_rKoLY2OK4?autoplay=1&loop=1&mute=1&playlist=o_rKoLY2OK4");
                    }
                }, 1000);
                return false;
            } else {
                jQuery('#video-wrapper .iframe-wrapper').removeClass('active');
                jQuery('#video-wrapper iframe').attr('src',"");
                jQuery('#video-wrapper iframe').css({'display': 'none'});
            }
        });
    });

